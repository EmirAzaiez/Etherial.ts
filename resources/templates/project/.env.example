NODE_ENV=development

# Database
DATABASE_SERVER=localhost
DATABASE_PORT=3306
DATABASE_NAME=etherial_db
DATABASE_USERNAME=root
DATABASE_PASSWORD=
DATABASE_DIALECT=postgres

# Http
HTTP_PORT=3000

# Http Auth
HTTP_AUTH_SECRET=super_secure_random_string_configured_in_env
# JWT access-token lifetime. Required because leaked tokens are otherwise
# permanently valid. Use short windows for access tokens.
HTTP_AUTH_EXPIRES_IN=15m

# Http Security
# Set to "true" ONLY when the app sits behind a trusted reverse proxy that
# sets X-Forwarded-For (Nginx, Cloudflare, ELB, etc.). When false (default),
# the raw socket address is used and XFF is ignored so attackers cannot
# rotate the header to evade rate / brute-force counters.
HTTP_TRUST_PROXY=false

# Sign in with Apple — set when /auth/apple is enabled.
# Service ID for web sign-in, bundle identifier for native iOS.
# Comma-separated to accept multiple audiences (web + iOS).
APPLE_AUDIENCE=

# Stripe (only set when ETHPaymentLeaf is enabled with the Stripe provider)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
